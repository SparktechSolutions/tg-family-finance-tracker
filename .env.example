# --- WhatsApp Cloud API (Meta) ---
# Get these from developers.facebook.com -> your app -> WhatsApp.
# Leave ACCESS_TOKEN EMPTY to run in dry-run mode (replies are logged, not sent).
# Fill it in only when you're ready to connect a real WhatsApp number.
WHATSAPP_VERIFY_TOKEN=change-me-to-any-random-string
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version, e.g. v21.0
WHATSAPP_API_VERSION=v21.0

# --- Telegram bot (free alternative to WhatsApp) ---
# Create a bot with @BotFather, then paste its token here. See docs/TELEGRAM.md.
# Leave empty if you're not using Telegram.
TELEGRAM_BOT_TOKEN=

# --- App ---
DATABASE_URL=sqlite:///./expenses.db
DEFAULT_CURRENCY=INR
LOG_LEVEL=INFO
